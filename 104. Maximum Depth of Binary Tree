/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public int maxDepth(TreeNode root) {
        if(root == null) return 0;

        List<Integer> pathLengths = new ArrayList<>();

        findAllPaths(root, 1, pathLengths);

        int max = 0;
        for(int length:pathLengths) {
            max = Math.max(max,length);
        }

        return max;
    }

    private void findAllPaths(TreeNode node,int currentDepth,List<Integer> pathLengths) {
        if(node==null) return;

        if(node.left == null && node.right == null) {
            pathLengths.add(currentDepth);return;
        }

        findAllPaths(node.left,currentDepth+1,pathLengths);
        findAllPaths(node.right,currentDepth+1,pathLengths);
    }
}
