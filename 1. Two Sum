     public int[] twoSum(int[] nums, int target) {
      HashMap<Integer,Integer> hmap = new HashMap<Integer,Integer>();
      for(int i=0;i<nums.length;i++) {
        int n = target - nums[i];
        if(hmap.containsKey(n)) {
            return new int[] {hmap.get(n),i};
        }
        hmap.put(nums[i],i);
      }
      return new int[]{};
    }

