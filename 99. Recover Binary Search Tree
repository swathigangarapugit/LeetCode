/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public void recoverTree(TreeNode root) {
        List<Integer> values = new ArrayList<>();
        inorderCollect(root,values);

        List<Integer> sortedValues = new ArrayList<>(values);
        Collections.sort(sortedValues);

        inorderReplace(root, sortedValues, new int[]{0});
    }
    private void inorderCollect(TreeNode node, List<Integer> values) {
        if(node == null) return;

        inorderCollect(node.left,values);
        values.add(node.val);
        inorderCollect(node.right,values);
    }

    private void inorderReplace(TreeNode node, List<Integer> sortedValues, int[] index) {
        if(node == null) return;

        inorderReplace(node.left,sortedValues,index);
        node.val=sortedValues.get(index[0]++);
        inorderReplace(node.right, sortedValues, index);
    }
}
