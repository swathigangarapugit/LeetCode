    int m=nums1.length; int n = nums2.length;int total=m+n;
    int i=0,j=0,current=0,previous=0;

    for(int count=0;count<=total/2;count++) {
        previous = current;

        if(i<m && (j>=n || nums1[i] <= nums2[j])) {
            current = nums1[i];i++;
        } else{
            current = nums2[j];j++;
        }
    }

    if(total%2 ==0)
        return (previous+current)/2.0;
    else
       return current;


